# Google Gemini API Key（必填，用於 Stage 2 LLM 驗證）
# 取得方式：https://makersuite.google.com/app/apikey
GEMINI_API_KEY=你的_Gemini_API_金鑰

# Gemini 模型（可選）
GEMINI_MODEL=gemini-2.5-flash

# Stage 1 語意模型（可選，預設從 HuggingFace 下載）
# MODEL_PATH=eric920609/20-multilingual-e5-large_fold_1

# Ollama 設定（可選）
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_HOST=http://localhost:11434
